# YonSuite API 配置示例文件
# 复制此文件为 .env 并填入实际值

# 必需配置
YONSUITE_APP_KEY=your_app_key_here
YONSUITE_APP_SECRET=your_app_secret_here
YONSUITE_TENANT_ID=your_tenant_id_here

# 可选配置
YONSUITE_GATEWAY_URL=https://c2.yonyoucloud.com/iuap-api-gateway
YONSUITE_TOKEN_URL=https://c2.yonyoucloud.com/iuap-api-auth
YONSUITE_LOG_LEVEL=INFO
YONSUITE_CACHE_DIR=/tmp/yonsuite_cache
YONSUITE_TOKEN_REFRESH_BUFFER=300
YONSUITE_HTTP_TIMEOUT=30
YONSUITE_MAX_RETRIES=3
YONSUITE_RETRY_DELAY=1.0
